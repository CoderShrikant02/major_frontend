digraph TomatoDiseaseClassifier {
    // Graph settings
    rankdir=TB;
    fontname="Arial Bold";
    fontsize=14;
    label="Tomato Disease Classifier - Data Flow Diagram";
    labelloc=t;
    
    // Node defaults
    node [fontname="Arial", fontsize=11];
    edge [fontname="Arial", fontsize=9];
    
    // External Entities (rectangles)
    User [shape=rect, style=filled, fillcolor="#22c55e", fontcolor=white, label="User"];
    
    // Processes (circles)
    node [shape=circle, style=filled, fillcolor="#16a34a", fontcolor=white, fixedsize=true, width=1.5];
    
    P1 [label="1.0\nRegister\n/Login"];
    P2 [label="2.0\nUpload\nImage"];
    P3 [label="3.0\nPreprocess\nImage"];
    P4 [label="4.0\nAI Model\nPredict"];
    P5 [label="5.0\nMap\nData"];
    P6 [label="6.0\nGet\nRecommend"];
    P7 [label="7.0\nSave\nHistory"];
    P8 [label="8.0\nDisplay\nResults"];
    
    // Data Stores (parallel lines)
    node [shape=cylinder, style=filled, fillcolor="#eab308", fontcolor=black, fixedsize=false, width=1.8];
    
    D1 [label="D1: Users\nMySQL"];
    D2 [label="D2: Predictions\nMySQL"];
    D3 [label="D3: TensorFlow\nModel"];
    D4 [label="D4: Display\nNames JSON"];
    D5 [label="D5: Insects\nJSON"];
    D6 [label="D6: Pesticides\nJSON"];
    D7 [label="D7: Class\nIndices JSON"];
    
    // Data Flow - Authentication
    User -> P1 [label="credentials"];
    P1 -> D1 [label="store/verify"];
    D1 -> P1 [label="user data"];
    P1 -> User [label="session\ntoken"];
    
    // Data Flow - Image Upload
    User -> P2 [label="tomato\nleaf image"];
    P2 -> P3 [label="raw image"];
    
    // Data Flow - Preprocessing
    P3 -> P4 [label="299x299\narray"];
    
    // Data Flow - Prediction
    D3 -> P4 [label="model\nweights"];
    P4 -> P5 [label="class index\n+ confidence"];
    
    // Data Flow - Mapping
    D7 -> P5 [label="index to\nclass name"];
    D4 -> P5 [label="friendly\nnames"];
    P5 -> P6 [label="disease\nname"];
    
    // Data Flow - Recommendations
    D5 -> P6 [label="pest\ninfo"];
    D6 -> P6 [label="pesticide\nlist"];
    P6 -> P7 [label="complete\nresult"];
    
    // Data Flow - Save & Display
    P7 -> D2 [label="save\nprediction"];
    P7 -> P8 [label="formatted\ndata"];
    P8 -> User [label="disease name\npest info\ntable"];
    
    // Grouping by subsystem
    subgraph cluster_0 {
        label="Authentication System";
        style=dashed;
        color="#666";
        P1; D1;
    }
    
    subgraph cluster_1 {
        label="AI Processing";
        style=dashed;
        color="#666";
        P2; P3; P4; D3;
    }
    
    subgraph cluster_2 {
        label="Data Mapping";
        style=dashed;
        color="#666";
        P5; P6; D4; D5; D6; D7;
    }
    
    subgraph cluster_3 {
        label="Output System";
        style=dashed;
        color="#666";
        P7; P8; D2;
    }
}